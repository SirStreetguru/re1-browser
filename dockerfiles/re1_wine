FROM i386/debian:bullseye

ARG DEBIAN_FRONTEND=noninteractive

# Install Wine and dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    wine \
    wine32 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create user and game directory
RUN useradd -m user || true
RUN mkdir -p /home/user/BiohazardPC

# Copy game files
COPY game/ /home/user/BiohazardPC/

# Set up Wine prefix
RUN su -c "WINEPREFIX=/home/user/.wine WINEARCH=win32 wineboot --init" user 2>/dev/null || true

# Create a launch script
RUN printf '#!/bin/bash\ncd /home/user/BiohazardPC\nexport WINEPREFIX=/home/user/.wine\nexport WINEARCH=win32\nwine Biohazard.exe\n' > /home/user/launch.sh && \
    chmod +x /home/user/launch.sh

WORKDIR /home/user/

ENV HOME="/home/user" TERM="xterm" USER="user" SHELL="/bin/bash" EDITOR="vim" LANG="en_US.UTF-8" LC_ALL="C"
RUN echo 'root:password' | chpasswd

CMD [ "/bin/bash" ]